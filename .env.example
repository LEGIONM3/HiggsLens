# HiggsLens Configuration Example
# Copy to .env and customize as needed

# Dataset & Paths
HIGGSLENS_DATA_DIR=./data
HIGGSLENS_ARTIFACTS_DIR=./artifacts
HIGGSLENS_CONFIG_DIR=./configs
# Optional override if official CERN portal is unreachable:
# HIGGSLENS_DATASET_URL=https://opendata.cern.ch/record/328/files/atlas-higgs-challenge-2014-v2.csv.gz

# Backend Server
HIGGSLENS_HOST=0.0.0.0
HIGGSLENS_PORT=8000
HIGGSLENS_DEBUG=True
HIGGSLENS_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Frontend Next.js
NEXT_PUBLIC_API_URL=http://localhost:8000
