# Python / Bytecode
__pycache__/
*.py[cod]
*$py.class
*.so
.venv/
env/
venv/
*.egg-info/
dist/
build/

# Node / Frontend
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/.env*.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Data & Artifacts (NEVER commit raw datasets or model weights)
data/raw/*
!data/raw/.gitkeep
data/interim/*
!data/interim/.gitkeep
data/processed/*
!data/processed/.gitkeep
artifacts/models/*
!artifacts/models/.gitkeep
artifacts/metrics/*
!artifacts/metrics/.gitkeep
artifacts/plots/*
!artifacts/plots/.gitkeep
artifacts/*.db
artifacts/*.sqlite
artifacts/*.jsonl

# Environment & IDEs
.env
.env.local
.DS_Store
.idea/
.vscode/
*.swp
*.swo
